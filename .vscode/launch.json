{
  "version": "0.2.0",
  "configurations": [
    
    {
      "name": "backend: attach debugger",
      "type": "java",
      "request": "attach",
      "hostName": "localhost",
      "port": 5005,
      "preLaunchTask": "backend: debug with infra"
    },
    {
      "name": "frontend: launch in Chrome",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "frontend: run",
      "url": "http://localhost:4200/",
      "webRoot": "${workspaceFolder}/frontend"
    },
    {
      "name": "frontend: attach in Edge",
      "type": "msedge",
      "request": "launch",
      "preLaunchTask": "frontend: run",
      "url": "http://localhost:4200/",
      "webRoot": "${workspaceFolder}/frontend"
    }
  ],
  "compounds": [
    {
      "name": "app: start and open frontend",
      "configurations": ["frontend: launch in Chrome"],
      "preLaunchTask": "app: run all"
    },
    {
      "name": "backend: debug only",
      "configurations": ["backend: attach debugger"]
    },
    {
      "name": "app: debug backend and open frontend",
      "configurations": ["backend: attach debugger", "frontend: launch in Chrome"]
    }
  ]
}
